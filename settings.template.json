{
  "env": {
    "FIREHOSE_MANAGEMENT_KEY": "YOUR_FIREHOSE_MANAGEMENT_KEY",
    "FIREHOSE_TAP_TOKEN": "YOUR_FIREHOSE_TAP_TOKEN",
    "API_KEY": "YOUR_SEOMCP_API_KEY"
  },
  "permissions": {
    "allow": [
      "mcp__seo-mcp-busbud",
      "mcp__ahrefs",
      "mcp__seo-memory",
      "mcp__squad-memory",
      "mcp__enterprise-seo",
      "mcp__seo-intelligence-mcp",
      "mcp__seo-enterprise-mcp",
      "mcp__ga4-busbud",
      "mcp__lumar-mcp",
      "mcp__gsc-busbud",
      "mcp__pencil",
      "mcp__squad-memory-os",
      "mcp__squad-memory-os__query_memory",
      "mcp__squad-memory-os__seo_elite_status",
      "mcp__squad-memory-os__memory_registry_overview",
      "mcp__squad-memory-os__memory_dataset_inspect",
      "mcp__squad-memory-os__memory_dataset_history",
      "mcp__squad-memory-os__memory_dataset_delta",
      "mcp__squad-memory-os__memory_run_ledger",
      "mcp__squad-memory-os__seo_patent_live_audit",
      "mcp__squad-memory-os__memory_federated_query",
      "mcp__squad-memory-os__memory_route_task",
      "mcp__squad-memory-os__memory_execution_plan"
    ],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/squad_memory/auto_ingest_hook.py \"$CLAUDE_CONVERSATION_ID\" \"$CLAUDE_SESSION_ID\" 2>/tmp/nautilus_hook.log &"
          }
        ]
      }
    ]
  },
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "preferences": {
    "coworkScheduledTasksEnabled": true,
    "sidebarMode": "code",
    "coworkWebSearchEnabled": true
  },
  "mcpServers": {
    "ahrefs": {
      "command": "npx",
      "args": [
        "-y",
        "@ahrefs/mcp"
      ],
      "env": {
        "API_KEY": "YOUR_AHREFS_API_KEY"
      }
    },
    "seo-mcp-busbud": {
      "command": "npx",
      "args": [
        "-y",
        "github:quantacodes/seomcp-proxy"
      ],
      "env": {
        "SEOMCP_API_KEY": "YOUR_SEOMCP_API_KEY",
        "GOOGLE_SERVICE_ACCOUNT": "YOUR_GOOGLE_SERVICE_ACCOUNT_JSON_BASE64",
        "GA4_PROPERTIES": "YOUR_GA4_PROPERTY_IDS_COMMA_SEPARATED",
        "GSC_PROPERTIES": "YOUR_GSC_SITE_URLS_COMMA_SEPARATED"
      }
    },
    "seo-memory": {
      "command": "python3",
      "args": [
        "$HOME/portable-repos/seo-vector-snapshot/mcp/seo_memory_mcp_server.py",
        "--db",
        "$HOME/squad_memory/squad_memory.db",
        "--skills-root",
        "$HOME/.codex/skills",
        "--task-packs",
        "$HOME/portable-repos/seo-vector-snapshot/tools/task_packs.json"
      ]
    },
    "squad-memory": {
      "command": "node",
      "args": [
        "$HOME/.codex/mcps/squad-memory-mcp/src/index.js"
      ]
    },
    "enterprise-seo": {
      "command": "node",
      "args": [
        "$HOME/.codex/mcps/enterprise-seo-mcp/src/index.js"
      ]
    },
    "seo-intelligence-mcp": {
      "command": "$HOME/Desktop/seo-intelligence-mcp/.venv/bin/python",
      "args": [
        "$HOME/Desktop/seo-intelligence-mcp/server.py"
      ]
    },
    "seo-enterprise-mcp": {
      "command": "$HOME/Desktop/seo-enterprise-mcp/.venv/bin/python",
      "args": [
        "$HOME/Desktop/seo-enterprise-mcp/server.py"
      ]
    },
    "ga4-busbud": {
      "command": "$HOME/.nvm/versions/node/v24.13.1/bin/mcp-server-ga4",
      "env": {
        "GA_PROPERTY_ID": "YOUR_GA4_PROPERTY_ID",
        "GOOGLE_APPLICATION_CREDENTIALS": "YOUR_GOOGLE_SERVICE_ACCOUNT_KEY_PATH"
      }
    },
    "lumar-mcp": {
      "command": "node",
      "args": [
        "$HOME/.codex/mcps/lumar-mcp/src/index.js"
      ],
      "env": {
        "LUMAR_CREDENTIALS_PATH": "YOUR_LUMAR_CREDENTIALS_PATH",
        "LUMAR_SESSION_CACHE_PATH": "YOUR_LUMAR_SESSION_CACHE_PATH",
        "LUMAR_RATE_LIMIT_MAX_REQUESTS": "60",
        "LUMAR_RATE_LIMIT_WINDOW_MS": "300000",
        "LUMAR_MIN_INTERVAL_MS": "1000"
      }
    },
    "pencil": {
      "command": "/Applications/Pencil.app/Contents/Resources/app.asar.unpacked/out/mcp-server-darwin-arm64",
      "args": [
        "--app",
        "antigravity"
      ]
    },
    "gsc-busbud": {
      "command": "$HOME/.nvm/versions/node/v24.13.1/bin/mcp-server-gsc",
      "env": {
        "GOOGLE_APPLICATION_CREDENTIALS": "YOUR_GOOGLE_SERVICE_ACCOUNT_KEY_PATH"
      }
    },
    "squad-memory-os": {
      "command": "python3",
      "args": [
        "$HOME/squad_memory/mcp/universal_memory_mcp_server.py",
        "--skills-root",
        "$HOME/.codex/skills",
        "--task-packs",
        "$HOME/squad_memory/task_packs.json"
      ],
      "env": {}
    }
  }
}